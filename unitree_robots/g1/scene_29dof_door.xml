<mujoco model="g1_29dof_door_opening">
  <include file="g1_29dof_collision.xml"/>

  <statistic center="0 0 0.5" extent="2.0"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="-130" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <material name="door_frame_mat" rgba="0.4 0.3 0.2 1"/>
    <material name="door_panel_mat" rgba="0.6 0.5 0.35 1"/>
    <material name="handle_mat" rgba="0.7 0.7 0.7 1" specular="0.8" shininess="0.5"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- Head camera: positioned roughly where G1's head would look -->
    <!-- This is a fixed world camera aimed at the door area -->
  

    <!-- Door assembly -->
    <body name="door_frame" pos="0.475 0.0 0.0" quat="0 0 0 1">
      <geom name="frame_left" type="box" size="0.03 0.03 0.95" pos="0 -0.4 0.95"
            material="door_frame_mat"/>
      <geom name="frame_right" type="box" size="0.03 0.03 0.95" pos="0 0.4 0.95"
            material="door_frame_mat"/>
      <geom name="frame_top" type="box" size="0.03 0.43 0.03" pos="0 0.0 1.9"
            material="door_frame_mat"/>

      <body name="door_panel" pos="0 -0.37 0.0">
        <joint name="door_hinge" type="hinge" axis="0 0 1" pos="0 0 0"
               range="0 1.5708" damping="0.1" frictionloss="0.02"/>
        <geom name="door_surface" type="box" size="0.02 0.37 0.93" pos="0 0.37 0.93"
              material="door_panel_mat" mass="1.0"/>

        <body name="handle_base" pos="0.025 0.68 0.95">
          <geom name="handle_plate" type="box" size="0.008 0.02 0.04"
                material="handle_mat"/>

          <body name="handle_lever" pos="0 0 0">
            <joint name="handle_joint" type="hinge" axis="0 1 0" pos="0 0 0"
                   range="0 0.7854" damping="0.3" stiffness="2.0"/>
            <geom name="handle_grip" type="capsule" size="0.01"
                  fromto="0 0 0 0.08 0 0" material="handle_mat"/>
            <geom name="handle_end" type="sphere" size="0.012" pos="0.08 0 0"
                  material="handle_mat"/>
          </body>
        </body>
      </body>
    </body>
  </worldbody>
  <option>
  <flag contact="enable"/>
</option>

<default>
  <geom contype="0" conaffinity="0"/>
</default>

<contact>
  <pair geom1="left_hand_collision" geom2="door_surface" 
        friction="0.8 0.8 0.001" solref="0.01 1" solimp="0.9 0.95 0.001"/>
  <pair geom1="right_hand_collision" geom2="door_surface" 
        friction="0.8 0.8 0.001" solref="0.01 1" solimp="0.9 0.95 0.001"/>
  <pair geom1="left_hand_collision" geom2="handle_grip" 
        friction="0.8 0.8 0.001" solref="0.01 1" solimp="0.9 0.95 0.001"/>
  <pair geom1="right_hand_collision" geom2="handle_grip" 
        friction="0.8 0.8 0.001" solref="0.01 1" solimp="0.9 0.95 0.001"/>
  <pair geom1="left_hand_collision" geom2="handle_end" 
        friction="0.8 0.8 0.001" solref="0.01 1" solimp="0.9 0.95 0.001"/>
  <pair geom1="right_hand_collision" geom2="handle_end" 
        friction="0.8 0.8 0.001" solref="0.01 1" solimp="0.9 0.95 0.001"/>
</contact>
</mujoco>
